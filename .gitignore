# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — all variants blocked
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase service account keys (never commit these)
serviceAccountKey.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json

# SSL / private keys / certificates
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# Claude Code local settings
.claude/

# OS files
Thumbs.db
Desktop.ini
